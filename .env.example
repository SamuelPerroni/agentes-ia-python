# ===========================================
# Configuração do Treinamento de Agentes IA
# ===========================================

# Chave da API do Groq (gratuita)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=sua api key aqui

# Modelo padrão (verifique modelos disponíveis em https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile

# Modelo de fallback para resiliência operacional
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
